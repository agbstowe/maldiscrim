# Fonction de reconstruction et interpolation
reconstruct_spectrum <- function(scores_row, mu, phi, targetGrid, currentGrid) {
# Calcul de la formule : Mu + Somme(Score * Phi) pour K= 2
y_grid <- mu + (scores_row[1] * phi[,1]) + (scores_row[2] * phi[,2])
# Redressement : on force les intensités négatives à 0 avant qu'elles ne soient interpolées sur les 20 664 points
y_grid <- pmax(y_grid, 0)
# Interpolation pour repasser de 400 points à 20 664 Daltons
y_final <- approx(x = currentGrid, y = y_grid, xout = targetGrid)$y
return(y_final)
}
