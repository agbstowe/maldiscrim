library(tidyr)
library(dplyr)
library(ggplot2)
library(maldiscrim)
spectra = process_maldi("E:/MASTER_STD/STAGE_M1_STD/stage_malditof/data/replicats_biologiques_tri")
set.seed(123) # Pour la reproductibilité
# Initialisation des variables
Dalton = 1:ncol(spectra)
colnames(spectra) = Dalton
ID_souche = as.integer(as.factor(rownames(spectra)))
# Transformation de la base de spectre en format long
df_long <- as.data.frame(spectra) %>%
mutate(ID = as.integer(as.factor(rownames(.)))) %>%
pivot_longer(cols = -ID,
names_to = "Dalton",
values_to = "Intensity") %>%
mutate(Dalton = as.numeric(Dalton))
# Création des inputs pour la FPCA
input_data <- MakeFPCAInputs(IDs = df_long$ID,
tVec = df_long$Dalton,
yVec = df_long$Intensity)
# Exécution de la FPCA avec sélection du nombre de composantes par AIC
res_fpca <- FPCA(input_data$Ly, input_data$Lt, optns = list(dataType = 'Dense', methodSelectK = "AIC"))
plot(res_fpca)
CreatePathPlot(res_fpca) # Représentation des intensités ajustées des spectres basée sur le résultat de la FPCA
# Extraction des scores (3 premières composantes)
scores_fpc1 <- res_fpca$xiEst[, 1]
scores_fpc2 <- res_fpca$xiEst[, 2]
scores_fpc3 <- res_fpca$xiEst[, 3]
# Palette de couleurs pour visualiser les 6 souches
palette_couleurs <- c("#E41A1C", "#377EB8", "#4DAF4A", "#984EA3", "#FF7F00", "#FFFF33")
### Superposition sur le graphique d'outliers
# dev.new(width = 10, height = 7)
# par(mar = c(5, 5, 4, 2))
# Plot de densité et d'Outliers
CreateOutliersPlot(res_fpca, optns = list(fIndices = c(1,2), variant = "KDE"))
# Projection et coloriage des points sur le graphique de densité
points(scores_fpc1, scores_fpc2,
col = palette_couleurs[ID_souche],
pch = 21,
cex = 1.1)
legend("bottomright",
legend = paste("Souche", 1:6),
col = palette_couleurs,
pch = 16,
title = "Souches",
bg = "white")
set.seed(42)
# Clustering sur les deux premières composantes de l'espace latent
res_fclust <- FClust(input_data$Ly, input_data$Lt,
optnsFPCA = list(dataType = 'Dense', methodSelectK = 2))
# Palette de couleurs pour les 3 classes
palette_clusters <- c( "#984EA3", "#FF7F00", "#FFFF33")
### Superposition sur le graphique d'outliers
# dev.new(width = 10, height = 7)
# par(mar = c(5, 5, 4, 2))
# Densité et Outliers
CreateOutliersPlot(res_fpca, optns = list(fIndices = c(1,2), variant = "KDE"))
# Projection et coloriage des points sur le graphique de densité
points(scores_fpc1, scores_fpc2,
col = palette_clusters[res_fclust$cluster],
pch = 21,
cex = 1.1)
legend("bottomright",
legend = paste("Cluster", 1:3),
col = palette_clusters,
pch = 16,
title = "Cluster",
bg = "white")
# Clustering sur les eux premières composantes de l'espace latent avec classification en deux classes
res_fclust <- FClust(input_data$Ly, input_data$Lt, k =2,
optnsFPCA = list(dataType = 'Dense', methodSelectK = 2))
# Palette de couleurs pour les 2 classes
palette_clusters <- c( "#984EA3", "#FF7F00")
### Superposition sur le graphique d'outliers
# dev.new(width = 10, height = 7)
# par(mar = c(5, 5, 4, 2))
# Densité et Outliers
CreateOutliersPlot(res_fpca, optns = list(fIndices = c(1,2), variant = "KDE"))
# Projection et coloriage des points sur le graphique de densité
points(scores_fpc1, scores_fpc2,
col = palette_clusters[res_fclust$cluster],
pch = 21,
cex = 1.1)
legend("bottomright",
legend = paste("Cluster", 1:2),
col = palette_clusters,
pch = 16,
title = "Cluster",
bg = "white")
scores <- res_fpca$xiEst[, 1:2]
# Estimation de la densité à noyau sur les scores 1 et 2
f_hat <- ks::kde(x = scores, eval.points = scores)$estimate
threshold_50 <- quantile(f_hat, 0.50)
# Identiifcation des points du centre (50%): uniquement ce qui est dans le noir
idx_centre <- which(f_hat >= threshold_50)
# Identification des points Outlier à l'extrême en haut à gauche en bleu
idx_outlier <- which(scores[,1] < -0.010 & scores[,2] > 0.002)
# Les points intermédiaires : ce qui reste, mais on limite la zone pour éviter les points trop isolés après 95%
idx_inter <- which(f_hat < threshold_50 & f_hat > quantile(f_hat, 0.15) & scores[,1] > -0.010)
# Fonction pour générer les points tout en contrôlant les frontières
simulate_safe <- function(indices, n_new, noise_sd) {
pts_base <- scores[indices, ]
new_pts <- pts_base[sample(1:nrow(pts_base), n_new, replace = TRUE), ] +
matrix(rnorm(n_new * 2, sd = noise_sd), ncol = 2)
return(new_pts)
}
set.seed(123)
sim_outlier <- simulate_safe(idx_outlier, 12, noise_sd = 0.0002)
sim_centre  <- simulate_safe(idx_centre, 43, noise_sd = 0.0006)
sim_inter   <- simulate_safe(idx_inter, 45, noise_sd = 0.0005)
# Visualisation
CreateOutliersPlot(res_fpca, optns = list(fIndices = c(1,2), variant = "KDE"))
points(sim_centre,  col = "black", pch = 3, cex = 0.8)
points(sim_outlier, col = "blue",  pch = 3, cex = 0.8)
points(sim_inter,   col = "cyan",  pch = 3, cex = 0.8)
# On récupère les éléments de base de la FPCA
mu <- res_fpca$mu              # Moyenne sur le grid
phi <- res_fpca$phi            # Fonctions propres sur le grid
workGrid <- res_fpca$workGrid  # Les valeurs de Dalton du grid (400 pts)
originalGrid <- input_data$Lt[[1]] # Les 20 664 Daltons d'origine
# On combine tous les scores simulés
all_sim_scores <- rbind(sim_centre, sim_outlier, sim_inter)
# Fonction de reconstruction et interpolation
reconstruct_spectrum <- function(scores_row, mu, phi, targetGrid, currentGrid) {
# Calcul de la formule : Mu + Somme(Score * Phi) pour K= 2
y_grid <- mu + (scores_row[1] * phi[,1]) + (scores_row[2] * phi[,2])
# Interpolation pour repasser de 400 points à 20 664 Daltons
y_final <- approx(x = currentGrid, y = y_grid, xout = targetGrid)$y
return(y_final)
}
# On génère tous les spectres simulés
simulated_spectra <- t(apply(all_sim_scores, 1, reconstruct_spectrum,
mu = mu, phi = phi,
targetGrid = originalGrid,
currentGrid = workGrid))
# Récupération des effectifs pour chaque groupe simulé
n_centre  <- nrow(sim_centre)
n_outlier <- nrow(sim_outlier)
n_inter   <- nrow(sim_inter)
# On assigne arbitrairement un numéro à chaque zone de l'image
labels_centre  <- rep("souche 1", n_centre)
labels_outlier <- rep("souche 2", n_outlier)
labels_inter   <- rep("souche3", n_inter)
# Vecteur complet des noms de lignes
all_labels <- c(labels_centre, labels_outlier, labels_inter)
rownames(simulated_spectra) <- all_labels
colnames(simulated_spectra) <- Dalton
idx_reel <- idx_outlier[1]
spectre_reel <- input_data$Ly[[idx_reel]]
malle_reel <- input_data$Lt[[idx_reel]]
spectre_sim <- simulated_spectra[45,]
# Graphique de comparaison
plot(malle_reel, spectre_reel, type = "l", col = "red",
xlab = "m/z (Dalton)", ylab = "Intensité",
main = "Visualisation d'un spectre réel vs spectre simulé")
lines(originalGrid, spectre_sim, col = "blue", lwd = 2)
legend("topright",
legend = c("Spectre Réel", "Spectre Simulé"),
col = c("red", "blue"), lty = 1, lwd = c(1, 2),
bg = "white")
# Définition de la palette de couleurs correspondant aux étiquettes
palette_sim <- c("souche 1" = "black", "souche 2" = "blue", "souche 3" = "cyan")
# Visualisation graphique
# On utilise originalGrid pour l'axe X et on calcule les limites de Y sur toute la base
plot(originalGrid, simulated_spectra[1,], type = "n",
ylim = range(simulated_spectra, na.rm = TRUE),
xlab = "m/z (Dalton)",
ylab = "Intensité",
main = "Profils spectraux simulés par souche")
# Boucle pour tracer chaque spectre avec sa couleur associée
for (i in 1:nrow(simulated_spectra)) {
# On récupère le nom de la souche pour la ligne i
nom_souche <- rownames(simulated_spectra)[i]
# On trace la ligne
lines(originalGrid, simulated_spectra[i,],
col = adjustcolor(palette_sim[nom_souche], alpha.f = 0.3),
lwd = 0.5)
}
# Ajout de la légende
legend("topright",
legend = names(palette_sim),
col = palette_sim,
lty = 1,
lwd = 2,
title = "Souches",
bg = "white")
View(simulated_spectra)
