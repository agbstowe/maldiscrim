# On utilise originalGrid pour l'axe X et on calcule les limites de Y sur toute la base
plot(originalGrid, simulated_spectra[1,], type = "n",
ylim = range(simulated_spectra, na.rm = TRUE),
xlab = "m/z (Dalton)",
ylab = "Intensité",
main = "Profils spectraux simulés par souche")
# Boucle pour tracer chaque spectre avec sa couleur associée
for (i in 1:nrow(simulated_spectra)) {
# On récupère le nom de la souche pour la ligne i
nom_souche <- rownames(simulated_spectra)[i]
# On trace la ligne
lines(originalGrid, simulated_spectra[i,],
col = adjustcolor(palette_sim[nom_souche], alpha.f = 0.3),
lwd = 0.5)
}
# Ajout de la légende
legend("topright",
legend = names(palette_sim),
col = palette_sim,
lty = 1,
lwd = 2,
title = "Souches",
bg = "white")
## On enregistre la base simulée
write.table(simulated_spectra,"E:/MASTER_STD/STAGE_M1_STD/stage_malditof/analyse/fplsda/les_fonctions/spectra100.csv",
sep = ",", dec = ".", row.names = TRUE, col.names = TRUE)
spectra100 <- simulated_spectra
## Enregistrement au format RData pour le package
save(spectra100, file = "E:/MASTER_STD/STAGE_M1_STD/packages_R/maldiscrim/data/spectra100.rda", compress = "xz")
data("spectra100")
res_spectra = fit.fPLS_DA(spectra100, ncomp=5)
round(res_spectra$pls_model$Xvar / res_spectra$pls_model$Xtotvar * 100, 2)
plot_spectra_3d(res_spectra)
plot_spectra_2d(res_spectra)
plsr
mwr
mvr
